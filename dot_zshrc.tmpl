{{ if .omarchy -}}
# History settings (zsh equivalents of bash histappend)
setopt APPEND_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
HISTSIZE=32768
SAVEHIST="${HISTSIZE}"

# Omarchy environment, PATH, aliases, and functions
source ~/.local/share/omarchy/default/bash/envs
source ~/.local/share/omarchy/default/bash/aliases
source ~/.local/share/omarchy/default/bash/functions

# Zsh keybindings (equivalent to omarchy inputrc)
setopt NO_CASE_GLOB
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
bindkey '^[[A' history-search-backward
bindkey '^[[B' history-search-forward
bindkey '^[[C' forward-char
bindkey '^[[D' backward-char

# Tool initializations
if command -v mise &> /dev/null; then
  eval "$(mise activate zsh)"
fi

if command -v zoxide &> /dev/null; then
  eval "$(zoxide init zsh)"
fi

if command -v fzf &> /dev/null; then
  [[ -f /usr/share/fzf/completion.zsh ]] && source /usr/share/fzf/completion.zsh
  [[ -f /usr/share/fzf/key-bindings.zsh ]] && source /usr/share/fzf/key-bindings.zsh
fi 

if command -v zmx &> /dev/null; then
  autoload -Uz compinit
  (( $+functions[compdef] )) || compinit
  eval "$(zmx completions zsh)"
fi

if command -v zmx &> /dev/null && command -v fzf &> /dev/null; then
  zmx-select() {
    local display
    display=$(zmx list 2>/dev/null | awk -F '\t' '
      {
        name = ""
        pid = ""
        clients = ""
        dir = ""

        for (i = 1; i <= NF; i++) {
          field = $i
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", field)

          if (field ~ /^(session_name|name)=/) {
            sub(/^[^=]+=/, "", field)
            name = field
          } else if (field ~ /^pid=/) {
            sub(/^pid=/, "", field)
            pid = field
          } else if (field ~ /^clients=/) {
            sub(/^clients=/, "", field)
            clients = field
          } else if (field ~ /^started_in=/) {
            sub(/^started_in=/, "", field)
            dir = field
          }
        }

        if (name != "") {
          printf "%-20s  pid:%-8s  clients:%-2s  %s\n", name, pid, clients, dir
        }
      }
    ')

    local output query key selected session_name
    local -a lines
    output=$({ [[ -n "$display" ]] && echo "$display"; } | fzf \
      --print-query \
      --expect=ctrl-n \
      --height=80% \
      --reverse \
      --prompt="zmx> " \
      --header="Enter: select | Ctrl-N: create new" \
      --preview='zmx history {1}' \
      --preview-window=right:60%:follow \
    )
    local rc=$?

    lines=("${(@f)output}")
    query="${lines[1]}"
    if [[ "${lines[2]}" == "ctrl-n" ]]; then
      key="${lines[2]}"
      selected="${lines[3]}"
    else
      key=""
      selected="${lines[2]}"
    fi

    if [[ "$key" == "ctrl-n" && -n "$query" ]]; then
      session_name="$query"
    elif [[ $rc -eq 0 && -n "$selected" ]]; then
      session_name=$(echo "$selected" | awk '{print $1}')
    elif [[ -n "$query" ]]; then
      session_name="$query"
    else
      return 130
    fi

    zmx attach "$session_name"
  }
fi

if command -v zmx &> /dev/null && command -v fzf &> /dev/null && [[ -z "$ZMX_SESSION" ]]; then
  zmx-select && exit
fi

alias c='claude'
alias lg='lazygit'
alias ld='lazydocker'

# OpenSSH agent (systemd user socket). Keep a forwarded SSH agent if one was supplied.
if [ -n "${XDG_RUNTIME_DIR:-}" ] && [ -S "$XDG_RUNTIME_DIR/ssh-agent.socket" ]; then
  if [ -z "${SSH_TTY:-}${SSH_CONNECTION:-}" ] || [ -z "${SSH_AUTH_SOCK:-}" ] || [ ! -S "${SSH_AUTH_SOCK:-}" ]; then
    export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"
  fi
fi

# In SSH sessions, use forwarded key for git commit signing (prefer GitHub key)
if [ -n "$SSH_TTY" ] || [ -n "$SSH_CONNECTION" ]; then
    _forwarded_key=$(ssh-add -L 2>/dev/null | grep -i github | head -1)
    [ -z "$_forwarded_key" ] && _forwarded_key=$(ssh-add -L 2>/dev/null | head -1)
    if [ -n "$_forwarded_key" ]; then
        export GIT_CONFIG_COUNT=1
        export GIT_CONFIG_KEY_0="user.signingkey"
        export GIT_CONFIG_VALUE_0="key::$_forwarded_key"
    fi
    unset _forwarded_key
fi
{{ end -}}

